{
  "name": "hunter-platform",
  "version": "1.8.0",
  "type": "module",
  "description": "猎头中介 API 平台 — 仅 HTTP API，供外部 AI Agent 通过 skill.md 直接对接",
  "main": "./out/main/index.js",
  "author": "Convo Contributors",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "node --env-file=.env --import tsx src/main/index.ts",
    "dev:watch": "node --env-file=.env --import tsx scripts/dev-watch.ts",
    "build": "tsc -p tsconfig.node.json && node scripts/copy-migrations.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.node.json",
    "start": "node --env-file=.env out/main/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:schemas": "vitest run tests/unit/schema-coverage.test.ts",
    "api:dev": "node --env-file=.env --import tsx src/main/index.ts",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "openapi:check": "tsx scripts/generate-openapi.ts --check",
    "capabilities:check": "tsx scripts/check-capabilities.ts",
    "capabilities:doc": "tsx scripts/generate-skill-capabilities.ts",
    "conformance:check": "tsx scripts/check-conformance-coverage.ts",
    "conformance:gen": "tsx scripts/generate-skill-md-scenarios.ts",
    "skill:changelog": "tsx scripts/sync-skill-md-changelog.ts",
    "lint:css": "stylelint \"src/**/*.css.ts\"",
    "lint:css:fix": "stylelint \"src/**/*.css.ts\" --fix",
    "build:web": "pnpm --filter @hunter-platform/admin-web run build",
    "dev:web": "pnpm --filter @hunter-platform/admin-web dev",
    "test:web": "pnpm --filter @hunter-platform/admin-web run test && pnpm --filter @hunter-platform/shared-web run test"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.49.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "bcryptjs": "^2.4.3",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-node": "^1.25.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "concurrently": "^10.0.3",
    "node-cron": "^4.3.0",
    "prom-client": "^15.1.3",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^3.2.7"
  },
  "workspaces": [
    "admin-web",
    "shared-web"
  ],
  "packageManager": "pnpm@9.15.0+sha512.76e2379760a4328ec4415815bcd6628dee727af3779aaa4c914e3944156c4299921a89f976381ee107d41f12cfa4b66681ca9c718f0668fa0831ed4c6d8ba56c"
}
