    "/v1/employer/recommendations/{id}/express-interest": {
      "post": {
        "summary": "Employer expresses interest in a recommendation (employer-only)",
        "security": [
          {
            "ApiKey": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
